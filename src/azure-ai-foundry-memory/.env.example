# ── Azure AI Foundry Project ──
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project-name
FOUNDRY_API_KEY=your-foundry-api-key

# ── Model Deployments ──
FOUNDRY_MODEL=gpt-4o
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Memory Scope (user identifier for memory isolation) ──
MEMORY_USER_SCOPE=demo_user
